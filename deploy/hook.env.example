# Webhook listener
DEPLOY_HOOK_HOST=127.0.0.1
DEPLOY_HOOK_PORT=9005
DEPLOY_HOOK_PATH=/github-webhook-products-information-manage
DEPLOY_HOOK_SECRET=replace_with_random_webhook_secret
DEPLOY_REPO=ciwei0600/ProductsInformationManage
DEPLOY_BRANCH=refs/heads/main
DEPLOY_SCRIPT=/opt/ProductsInformationManage/deploy/deploy.sh
DEPLOY_LOG=/var/log/products-information-manage/deploy-hook.log

# deploy.sh variables
PROJECT_DIR=/opt/ProductsInformationManage
BRANCH=main
COMPOSE_FILE=/opt/ProductsInformationManage/docker-compose.yml
COMPOSE_ENV_FILE=/opt/ProductsInformationManage/deploy/app.env
COMPOSE_PROJECT_NAME=productsinformationmanage
SERVICE_NAME=web
DOCKER_BIN=/usr/bin/docker
GIT_SSH_COMMAND=
